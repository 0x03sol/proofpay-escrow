# ProofPay — GIWA Sepolia deployment configuration
# Copy this file to .env and fill in PRIVATE_KEY. NEVER commit .env.

# --- Network ---
GIWA_RPC_URL=https://sepolia-rpc.giwa.io
EXPLORER_API_KEY=

# --- Deployer (REQUIRED) ---
# Hex private key WITH 0x prefix. Fund this address with GIWA Sepolia ETH from https://faucet.giwa.io
PRIVATE_KEY=

# --- Optional configuration (defaults applied if left blank) ---
# DojangScroll read layer on GIWA Sepolia (leave as-is unless Dojang redeploys).
DOJANG_SCROLL=0xd5077b67dcb56caC8b270C7788FC3E6ee03F17B9
# Protocol fee in basis points (max 100 = 1.0%). Default 50 = 0.5%.
FEE_BPS=50
# Fee recipient / arbitrator / final owner. Default to the deployer address if blank.
FEE_RECIPIENT=
ARBITRATOR=
PROOFPAY_OWNER=
