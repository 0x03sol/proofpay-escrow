# ProofPay backend / indexer configuration

# Chain
CHAIN_ID=91342
GIWA_RPC_URL=https://sepolia-rpc.giwa.io

# Where to read deployed contract addresses from (written by the deploy script).
# Defaults to ../contracts/deployments/<CHAIN_ID>.json
# DEPLOYMENTS_PATH=../contracts/deployments/91342.json

# Optional explicit address overrides (otherwise read from the deployments file)
# INVOICE_REGISTRY=
# PROOFPAY_ESCROW=
# DISPUTE_MODULE=
# DOJANG_VERIFIER=

# Indexer
# START_BLOCK overrides the deployment block for backfill start.
# START_BLOCK=
POLL_INTERVAL_MS=4000
LOG_CHUNK_SIZE=5000
DB_PATH=./data/proofpay.db

# API
PORT=8899
HOST=0.0.0.0
INDEXER_ENABLED=true
