{
  "name": "proofpay-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ProofPay event indexer + read API for GIWA Sepolia",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "indexer": "node --experimental-sqlite --import tsx src/indexer-main.ts",
    "backfill": "node --experimental-sqlite --import tsx src/indexer-main.ts --once",
    "api": "node --experimental-sqlite --import tsx src/server.ts",
    "start": "node --experimental-sqlite --import tsx src/server.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "viem": "^2.21.55"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
